{
  "name": "assembly-manager",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "frontend/apps/assembly-manager/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vite --config frontend/apps/assembly-manager/vite.config.ts --host 0.0.0.0 --port 4200"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "pnpm exec tsc -p frontend/apps/assembly-manager/tsconfig.json --noEmit && pnpm exec vite build --config frontend/apps/assembly-manager/vite.config.ts"
      }
    }
  }
}
